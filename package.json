{
  "name": "unify-mcp",
  "version": "0.2.0",
  "description": "Use Claude to query and update your Unify GTM CRM — people, companies, sequences, lists, plays, audiences, notes, tasks. Log in with your Unify account. No API keys.",
  "type": "module",
  "bin": {
    "unify-mcp": "dist/cli.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/footcarts/unify-mcp.git"
  },
  "homepage": "https://github.com/footcarts/unify-mcp",
  "bugs": "https://github.com/footcarts/unify-mcp/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "unify",
    "unifygtm",
    "crm",
    "gtm",
    "sales",
    "outbound",
    "auth0"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "tough-cookie": "^4.1.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/tough-cookie": "^4.0.5",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
